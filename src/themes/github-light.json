{
  "id": "github-light",
  "name": "GitHub Light",
  "author": "Know",
  "description": "Clean light theme inspired by GitHub's default light palette",
  "version": "1.0.0",
  "mode": "light",
  "colors": {
    "bgBase":     "#f0f2f5",
    "bgSurface":  "#ffffff",
    "bgElevated": "#f6f8fa",
    "bgInput":    "#f6f8fa",
    "bgHover":    "#eaeef2",
    "bgSelected": "#ddf4ff",
    "bgOverlay":  "#f0f2f5ee",
    "textNormal":  "#1f2328",
    "textMuted":   "#656d76",
    "textFaint":   "#afb8c1",
    "textOnAccent":"#ffffff",
    "textLink":    "#0969da",
    "accentColor": "#0969da",
    "accentHover": "#0757b5",
    "accentMuted": "#0969da1a",
    "borderSubtle":  "#eaeef2",
    "borderDefault": "#d0d7de",
    "borderFocus":   "#0969da",
    "colorRed":    "#cf222e",
    "colorGreen":  "#116329",
    "colorYellow": "#9a6700",
    "colorBlue":   "#0969da",
    "colorPurple": "#8250df",
    "colorOrange": "#bc4c00",
    "codeBg":        "#f6f8fa",
    "codeText":      "#1f2328",
    "codeKeyword":   "#cf222e",
    "codeString":    "#0a3069",
    "codeComment":   "#6e7781",
    "codeNumber":    "#0550ae",
    "codeType":      "#953800",
    "codeFunction":  "#8250df",
    "codePunct":     "#656d76",
    "codeOperator":  "#cf222e",
    "codeAttribute": "#0550ae",
    "titlebarBg":            "#e7eaed",
    "sidebarBg":             "#f6f8fa",
    "activityBarBg":         "#e7eaed",
    "activityBarIcon":       "#afb8c1",
    "activityBarIconActive": "#0969da",
    "activityBarIndicator":  "#0969da",
    "tabBarBg":              "#f0f2f5",
    "tabBg":                 "#f0f2f5",
    "tabActiveBg":           "#ffffff",
    "tabText":               "#afb8c1",
    "tabTextActive":         "#1f2328",
    "tabBorder":             "#d0d7de",
    "scrollbarThumb":        "#d0d7de"
  },
  "fonts": {
    "ui":        "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "monospace": "'Fira Code', 'JetBrains Mono', Consolas, monospace",
    "text":      "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
  },
  "radius": { "sm": "6px", "md": "6px", "lg": "8px", "xl": "12px" }
}
